---
import IconHash from "@/assets/icons/IconHash.svg";

export interface Props {
  tag: string;
  tagName: string;
  size?: "sm" | "lg";
}

const { tagName, size = "sm" } = Astro.props;
---

<li
  class:list={[
    "group inline-block group-hover:cursor-pointer",
    size === "sm" ? "my-1 underline-offset-4" : "mx-1 my-3 underline-offset-8",
  ]}
>
  <span
    class:list={[
      "relative pr-2 text-lg",
      { "text-sm": size === "sm" },
    ]}
  >
    <IconHash
      class:list={[
        "inline-block opacity-80",
        { "-mr-3.5 size-4": size === "sm" },
        { "-mr-5 size-6": size === "lg" },
      ]}
    />
    &nbsp;<span>{tagName}</span>
  </span>
</li>
