---
import { getLocale } from "@/utils/i18n";
import Hr from "./Hr.astro";
import Socials from "./Socials.astro";

export interface Props {
  noMarginTop?: boolean;
}

const { noMarginTop = false } = Astro.props;
const locale = getLocale(Astro.url.pathname);
const footerText =
  locale === "he"
    ? "אפשר לגנוב את האתר ← CC BY 4.0 · Code MIT"
    : "Steal this site ➜ CC BY 4.0 · Code MIT";
---

<footer class:list={["w-full", { "mt-auto": !noMarginTop }]}>
  <Hr noPadding />
  <div
    class="flex flex-col items-center justify-between py-6 sm:flex-row-reverse sm:py-4"
  >
    <Socials centered />
    <div class="my-2 flex flex-col items-center whitespace-nowrap sm:flex-row">
      <a href="https://github.com/omribz156/omribz.me" target="_blank" rel="noopener noreferrer" class="hover:text-accent">
        {footerText}
      </a>
    </div>
  </div>
</footer>
