---
import { getLocale } from "@/utils/i18n";
import Hr from "./Hr.astro";
import Socials from "./Socials.astro";

export interface Props {
  noMarginTop?: boolean;
  hideSocialsOnMobile?: boolean;
}

const { noMarginTop = false, hideSocialsOnMobile = false } = Astro.props;
const locale = getLocale(Astro.url.pathname);
const footerText =
  locale === "he"
    ? {
        label: "אפשר לגנוב את האתר",
        arrow: "←",
      }
    : {
        label: "Steal this site",
        arrow: "➜",
      };
---

<footer class:list={["w-full", { "mt-auto": !noMarginTop }]}>
  <Hr noPadding />
  <div
    class="flex flex-col items-center justify-between py-6 sm:flex-row-reverse sm:py-4"
  >
    <div class:list={[{ "hidden sm:block": hideSocialsOnMobile }]}>
      <Socials centered />
    </div>
    <div class="my-2 flex max-w-full flex-col items-center text-center sm:flex-row">
      <a
        href="https://github.com/omribz156/omribz.me"
        target="_blank"
        rel="noopener noreferrer"
        class="flex max-w-full flex-wrap items-center justify-center gap-x-2 gap-y-1 leading-relaxed hover:text-accent"
      >
        <span>{footerText.label}</span>
        <span aria-hidden="true">{footerText.arrow}</span>
        <span>CC BY 4.0</span>
        <span aria-hidden="true">·</span>
        <span>Code MIT</span>
      </a>
    </div>
  </div>
</footer>
